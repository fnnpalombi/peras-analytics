# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored and must NEVER be committed.

# Your PostHog personal API key (create one in PostHog:
# Settings -> Personal API keys -> "Create personal API key").
# Give it "Query Read" scope (and read access to the relevant project).
POSTHOG_API_KEY=phx_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your PostHog host. Common values:
#   US Cloud:  https://us.posthog.com
#   EU Cloud:  https://eu.posthog.com
#   (older US projects may use https://app.posthog.com)
#   self-hosted: your instance URL
POSTHOG_HOST=https://us.posthog.com

# Your PostHog project ID (an integer). Find it in PostHog:
# Settings -> Project -> Project ID, or in the URL /project/<ID>/...
POSTHOG_PROJECT_ID=12345
